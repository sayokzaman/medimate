# ====================================================================
# Python Virtual Environment (venv)
# ====================================================================
# Ignores the local environment binaries, libraries, and config
.venv/
bin
include
lib
lib64
share
pyvenv.cfg

# ====================================================================
# Audio / Testing Artifacts
# ====================================================================
# Ignores local recording tests, but keeps the code clean
*.wav

# ====================================================================
# Standard Python Caches
# ====================================================================
__pycache__/
*.py[cod]
*$py.class

.env
